---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle';

interface Props {
  title?: string;
  active?: 'today' | 'history' | 'persistent';
}

const { title = 'gh-daily', active = 'today' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { href: `${base}/`, label: '今日', key: 'today' },
  { href: `${base}/history/`, label: '历史', key: 'history' },
  { href: `${base}/persistent/`, label: '常驻榜', key: 'persistent' },
] as const;
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="GitHub Trending 归档与浏览" />
    <title>{title}</title>
    <script is:inline data-base={base}>
      const base = document.currentScript?.getAttribute('data-base') || '';
      const theme = localStorage.getItem('gh-daily-theme');
      if (theme === 'dark' || (!theme && matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register(`${base}/sw.js`);
      }
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-10 border-b border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur-sm px-4 py-3">
      <div class="mx-auto flex max-w-5xl items-center justify-between">
        <a href={`${base}/`} class="text-lg font-bold tracking-tight shrink-0">
          <span class="text-[var(--color-accent)]">gh</span>-daily
        </a>
        <div class="flex items-center gap-1">
          <nav class="flex items-center gap-0.5 text-sm">
            {navItems.map((item) => (
              <a
                href={item.href}
                class:list={[
                  'rounded-md px-2.5 py-1.5 transition-colors sm:px-3',
                  active === item.key
                    ? 'bg-[var(--color-accent-soft)] text-[var(--color-accent)] font-medium'
                    : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)]',
                ]}
              >
                {item.label}
              </a>
            ))}
          </nav>
          <div class="ml-1">
            <ThemeToggle client:load />
          </div>
        </div>
      </div>
    </header>
    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-6">
      <slot />
    </main>
    <footer class="border-t border-[var(--color-border)] px-4 py-4">
      <div class="mx-auto max-w-5xl flex items-center justify-between text-xs text-[var(--color-text-muted)]">
        <span>GitHub Trending 每日归档</span>
        <a href="https://github.com/kingcos/gh-daily" target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-accent)]">
          GitHub
        </a>
      </div>
    </footer>
  </body>
</html>
